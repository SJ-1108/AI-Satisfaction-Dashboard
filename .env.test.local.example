# ──────────────────────────────────────────────────────────────
# 실제 DB 모드(테스트 서버) 환경변수 템플릿
# 이 파일을 .env.test.local 로 복사한 뒤 dev Supabase 값을 채우세요.
# `npm run dev:db` 가 .env.test.local 을 로드해 실제 DB 모드로 실행합니다.
# .env.test.local 은 .gitignore(.env*.local) 로 커밋되지 않습니다. (키 노출 금지)
# 기본 `npm run dev` 는 .env.local(더미 모드) 그대로 동작합니다.
# ──────────────────────────────────────────────────────────────

# [공개] 브라우저에 노출되어도 되는 값 (anon 키는 RLS로 보호됨)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-DEV-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-DEV-ANON-KEY

# [공개] 사번 → 이메일 변환 도메인 (내부 변환용)
NEXT_PUBLIC_INTERNAL_EMAIL_DOMAIN=megastudyedu.com

# [서버 전용] 절대 프론트에 노출 금지 — 적재/동기화/시드에서만 사용 (RLS 우회)
SUPABASE_SERVICE_ROLE_KEY=YOUR-DEV-SERVICE-ROLE-KEY
