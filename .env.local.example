# ──────────────────────────────────────────────────────────────
# 환경변수 템플릿 — 이 파일을 .env.local 로 복사한 뒤 값을 채우세요.
# .env.local 은 .gitignore 에 의해 커밋되지 않습니다. (NFR-2: 키 노출 금지)
# ──────────────────────────────────────────────────────────────

# [공개] 브라우저에 노출되어도 되는 값 (anon 키는 RLS로 보호됨)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# [공개] 사번 → 이메일 변환 도메인 (사용자에게 노출되지 않음, 내부 변환용)
# 예) 20240278 → 20240278@internal.local
NEXT_PUBLIC_INTERNAL_EMAIL_DOMAIN=internal.local

# [서버 전용] 절대 프론트에 노출 금지 — 적재/동기화/시드에서만 사용 (RLS 우회)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# [서버 전용] 단계 4(자동 동기화)에서 사용 — 지금은 비워둬도 됩니다.
METABASE_URL=https://metabase.video-mint.net
METABASE_API_KEY=
METABASE_CARD_ID=
# Vercel Cron 엔드포인트 보호용 시크릿 (단계 4에서 사용)
CRON_SECRET=
